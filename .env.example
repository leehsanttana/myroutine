# Push de lembretes (opcional). Sem estas variáveis, o app usa o lembrete
# local (só com o app aberto). Com elas, usa o Worker de push (app fechado).
# Copie para .env.local e preencha após implantar o Worker (veja worker/README.md).

# Chave pública VAPID (a mesma configurada no Worker).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# URL do Worker de push, ex.: https://myroutine-push.SEU-SUBDOMINIO.workers.dev
NEXT_PUBLIC_PUSH_API=
